{
  "manifest_version": 3,
  "name": "AbleSci Assist Guard",
  "description": "科研通 / AbleSci 文献互助半自动化应助 Chrome 插件：辅助打开求助、跳转出版商、定位 PDF 下载路径。",
  "version": "0.3.8",
  "permissions": ["storage", "tabs", "scripting", "downloads", "clipboardWrite"],
  "host_permissions": [
    "https://www.ablesci.com/*",
    "https://api.openalex.org/*",
    "https://doi.org/*",
    "https://scholar.google.com/*",
    "https://www.google.com/*",
    "https://www.sciencedirect.com/*",
    "https://pdf.sciencedirectassets.com/*"
  ],
  "action": {
    "default_title": "AbleSci Assist Guard",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ablesci.com/*",
        "https://www.sciencedirect.com/*",
        "https://pdf.sciencedirectassets.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
